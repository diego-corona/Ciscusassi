# Copia in .env e compila con i valori reali. NON committare .env nel repo.

# URL del backend raggiungibile dal browser (con /api alla fine)
API_URL=https://url/api

# API Key TomTom per le mappe
TOMTOM_API_KEY=la_tua_chiave_tomtom

# Chiave JWT (deve essere uguale a JWT_SECRET_KEY nel file Codice/Backend/.env)
JWT_SECRET_KEY=genera_una_stringa_casuale_sicura
